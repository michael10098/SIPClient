<Window x:Class="SIPClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SIPClient"
        mc:Ignorable="d"
        Title="SIP Client" Height="650" Width="500">
    <Window.Resources>
        <Style x:Key="DialButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#999"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B0B0B0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="Images/Background.png" Stretch="UniformToFill"/>
        </Grid.Background>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock x:Name="TitleText" Text="SIP Dialer" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" TextAlignment="Center"/>
            <TextBlock Text="Designed by Michael Van Hulle" FontSize="12" FontWeight="Bold" Margin="0,0,0,20" TextAlignment="Center"/>

            <TextBox x:Name="DisplayBox" Height="60" FontSize="28" TextAlignment="Right" Padding="10" Margin="0,0,0,20" IsReadOnly="True" Background="White" Foreground="Black"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1: 1 2 3 -->
                <Button Grid.Row="0" Grid.Column="0" Content="1" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="1" Content="2" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>
                <Button Grid.Row="0" Grid.Column="2" Content="3" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>

                <!-- Row 2: 4 5 6 -->
                <Button Grid.Row="1" Grid.Column="0" Content="4" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="1" Content="5" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>
                <Button Grid.Row="1" Grid.Column="2" Content="6" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>

                <!-- Row 3: 7 8 9 -->
                <Button Grid.Row="2" Grid.Column="0" Content="7" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>
                <Button Grid.Row="2" Grid.Column="1" Content="8" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>
                <Button Grid.Row="2" Grid.Column="2" Content="9" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>

                <!-- Row 4: * 0 # -->
                <Button Grid.Row="3" Grid.Column="0" Content="*" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>
                <Button Grid.Row="3" Grid.Column="1" Content="0" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>
                <Button Grid.Row="3" Grid.Column="2" Content="#" Click="DialButton_Click" Style="{StaticResource DialButtonStyle}"/>

                <!-- Row 5: Call and Clear buttons spanning full width -->
                <Button Grid.Row="4" Grid.Column="0" Content="Clear" Click="ClearButton_Click" Margin="5" Padding="10" Height="40" Background="#FF6B6B" Foreground="White" FontSize="14" FontWeight="Bold"/>
                <Button Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Content="Call" Click="CallButton_Click" Margin="5" Padding="10" Height="40" Background="#4CAF50" Foreground="White" FontSize="14" FontWeight="Bold"/>

                <!-- Row 6 Answer button spanning full width -->
                <Button x:Name="AnswerButton" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Content="Answer Call" IsEnabled="False" Click="AnswerButton_Click" Background="#6b8eff" Foreground="Black" Style="{StaticResource ActionButtonStyle}"/>

                <!-- Row 7 Hang up button spanning full width -->
                <Button x:Name="HangupButton" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Content="Hangup" IsEnabled="False" Click="HangupButton_Click" Background="#6b8eff" Foreground="Black" Style="{StaticResource ActionButtonStyle}"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
